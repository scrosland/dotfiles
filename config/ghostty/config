# vim: set filetype=ghostty :

# last uncommented entry which can be found on disk will be the one used
theme = Github
theme = OneHalfLight
theme = GitHub Light Default
#foreground = #333333
cursor-color = #333333
selection-background = #f1d007
selection-foreground = #333333

font-family = Input Mono
font-size = 13
# tighten up the horizontal spacing for Input Mono
#adjust-cell-width = -10%
# disable programming ligatures
font-feature = -calt

# initial window size
window-height = 42
window-width = 82

clipboard-read = allow
clipboard-write = allow

macos-titlebar-style = native
macos-non-native-fullscreen = false
# macos-option-as-alt = left

window-inherit-working-directory = false
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Shell integration `cursor` (default) sets the cursor to a vertical bar
shell-integration-features = no-cursor

